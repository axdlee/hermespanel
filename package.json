{
  "name": "hermespanel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hermes Agent 桌面管理客户端",
  "scripts": {
    "dev": "npm run dev:vite",
    "dev:vite": "vite --host 127.0.0.1 --port 1420",
    "build": "tsc && vite build",
    "check": "npm run build && cargo test --manifest-path src-tauri/Cargo.toml",
    "check:ci": "cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --check && cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings && cargo test --manifest-path src-tauri/Cargo.toml && npm run build && npm run test",
    "preview": "vite preview --host 127.0.0.1 --port 1420",
    "tauri": "tauri",
    "tauri:dev": "bash ./scripts/tauri-dev-clean.sh",
    "tauri:build": "tauri build",
    "tauri:build:debug": "tauri build --debug",
    "docs:capture:mac": "bash scripts/capture-macos-window.sh",
    "icon:regen": "tauri icon src-tauri/icons/icon.svg -o src-tauri/icons",
    "lint": "eslint src --report-unused-disable-directives",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "lint-staged": "lint-staged",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.8.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/ui": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.1.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^7.1.3",
    "vitest": "^4.1.4"
  }
}
